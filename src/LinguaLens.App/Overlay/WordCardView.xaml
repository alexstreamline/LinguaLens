<UserControl x:Class="LinguaLens.App.Overlay.WordCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MinWidth="240" MaxWidth="400">
        <!-- Header: word, pos badge, transcription, flag -->
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="WordText" FontSize="18" FontWeight="Bold" />
            <Border x:Name="PosBadge" Margin="8,0,0,0" Padding="4,1" CornerRadius="3"
                    Background="#EEF2FF">
                <TextBlock x:Name="PosText" FontSize="11" Foreground="#4F46E5" />
            </Border>
        </StackPanel>
        <TextBlock x:Name="TranscriptionText" Foreground="Gray" FontSize="12" />

        <!-- Translation -->
        <TextBlock x:Name="TranslationText" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0" />

        <!-- Comment -->
        <TextBlock x:Name="CommentText" FontStyle="Italic" Foreground="Gray"
                   TextWrapping="Wrap" Visibility="Collapsed" />

        <!-- Examples -->
        <ItemsControl x:Name="ExamplesList" Margin="0,6,0,0" />

        <!-- Footer -->
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Margin="0,0,4,0" />
            <Button x:Name="CopyButton" Content="Копировать" Margin="0,0,4,0" />
            <Button x:Name="TranslateSentenceButton" Content="Перевести предложение →" />
        </StackPanel>
    </StackPanel>
</UserControl>

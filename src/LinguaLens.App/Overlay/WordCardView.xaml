<UserControl x:Class="LinguaLens.App.Overlay.WordCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MinWidth="220" MaxWidth="400">

        <!-- Header: word + pos badge -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="WordText" FontSize="18" FontWeight="Bold" />
            <Border x:Name="PosBadge" Margin="8,0,0,0" Padding="5,2" CornerRadius="4"
                    Background="#EEF2FF" VerticalAlignment="Center">
                <TextBlock x:Name="PosText" FontSize="11" Foreground="#4F46E5" />
            </Border>
        </StackPanel>

        <!-- Transcription -->
        <TextBlock x:Name="TranscriptionText" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0" />

        <!-- Translation -->
        <TextBlock x:Name="TranslationText" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,0"
                   TextWrapping="Wrap" />

        <!-- Comment -->
        <TextBlock x:Name="CommentText" FontStyle="Italic" Foreground="#6B7280"
                   TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"
                   Visibility="Collapsed" />

        <!-- Examples -->
        <ItemsControl x:Name="ExamplesList" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,3,0,0">
                        <TextBlock Text="{Binding Original}" FontStyle="Italic"
                                   TextWrapping="Wrap" FontSize="12" />
                        <TextBlock Text="{Binding Translation}" Foreground="#6B7280"
                                   TextWrapping="Wrap" FontSize="12" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Footer buttons -->
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="CopyButton" Content="Копировать" Padding="8,3" Margin="0,0,6,0"
                    FontSize="12" Cursor="Hand" />
            <Button x:Name="TranslateSentenceButton" Content="Предложение →" Padding="8,3"
                    FontSize="12" Cursor="Hand" />
        </StackPanel>
    </StackPanel>
</UserControl>

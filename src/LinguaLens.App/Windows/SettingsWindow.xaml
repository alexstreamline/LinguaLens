<Window x:Class="LinguaLens.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки — LinguaLens"
        Width="420" Height="480"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <!-- API -->
        <GroupBox Header="API" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Провайдер:" Width="100" />
                    <ComboBox x:Name="ProviderCombo" Width="140">
                        <ComboBoxItem Content="Groq" Tag="groq" />
                        <ComboBoxItem Content="Gemini" Tag="gemini" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Label Content="API ключ:" Width="100" />
                    <PasswordBox x:Name="ApiKeyBox" Width="200" />
                    <Button x:Name="ShowKeyButton" Content="👁" Width="24" Margin="4,0,0,0" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Behavior -->
        <GroupBox Header="Поведение" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Задержка (мс):" Width="120" />
                    <Slider x:Name="DebounceSlider" Minimum="100" Maximum="1000" Width="160" />
                    <TextBlock x:Name="DebounceValue" Width="40" Margin="4,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Label Content="Горячая клавиша:" Width="120" />
                    <TextBox x:Name="HotKeyBox" Width="120" />
                </StackPanel>
                <CheckBox x:Name="DetectEnglishCheck" Content="Английский" Margin="0,4,0,0" />
                <CheckBox x:Name="DetectSpanishCheck" Content="Испанский" Margin="0,4,0,0" />
                <CheckBox x:Name="AutoSaveCheck" Content="Автосохранение в словарь" Margin="0,4,0,0" />
            </StackPanel>
        </GroupBox>

        <!-- Appearance -->
        <GroupBox Header="Внешний вид" Margin="0,0,0,8">
            <StackPanel Margin="8" Orientation="Horizontal">
                <Label Content="Тема:" Width="60" />
                <RadioButton x:Name="LightTheme" Content="Светлая" GroupName="Theme" Margin="0,0,8,0" />
                <RadioButton x:Name="DarkTheme" Content="Тёмная" GroupName="Theme" />
            </StackPanel>
        </GroupBox>

        <!-- System -->
        <GroupBox Header="Система" Margin="0,0,0,8">
            <CheckBox x:Name="StartWithWindowsCheck" Content="Запускать с Windows" Margin="8" />
        </GroupBox>

        <Button x:Name="SaveButton" Content="Сохранить" HorizontalAlignment="Right"
                Width="100" Margin="0,8,0,0" />
    </StackPanel>
</Window>
